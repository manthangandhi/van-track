{
  "name": "vantrack-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run icons && vite build",
    "build:pages": "npm run icons && VITE_BASE_PATH=/van-track/ vite build && node scripts/prepare-gh-pages.mjs",
    "preview": "vite preview",
    "preview:pages": "npm run build:pages && vite preview --base /van-track/",
    "lint": "eslint src --ext js,jsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test e2e/enterprise-qa.spec.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "postinstall": "node scripts/copy-face-models.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.31.0",
    "@vladmandic/face-api": "^1.7.15",
    "axios": "^1.4.0",
    "html2canvas": "^1.4.1",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.14.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.3.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.44.0",
    "eslint-plugin-react": "^7.32.2",
    "postcss": "^8.4.24",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.2",
    "vite": "^8.1.3",
    "vitest": "^3.0.5"
  }
}
